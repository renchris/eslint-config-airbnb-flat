{
  "name": "eslint-config-airbnb-flat",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.3.0",
  "description": "Airbnb's ESLint config for ESLint 9+ flat config — 1:1 rule parity, audited against source",
  "license": "MIT",
  "author": "Chris Ren",
  "repository": {
    "type": "git",
    "url": "https://github.com/renchris/eslint-config-airbnb-flat.git"
  },
  "homepage": "https://github.com/renchris/eslint-config-airbnb-flat#readme",
  "bugs": "https://github.com/renchris/eslint-config-airbnb-flat/issues",
  "keywords": [
    "eslint",
    "eslintconfig",
    "eslint-config",
    "airbnb",
    "flat-config",
    "typescript",
    "react",
    "eslint9"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": "^20.9.0 || >=21.1.0"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "typescript": ">=4.8.4"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "@eslint/js": "^9.0.0",
    "confusing-browser-globals": "^1.0.11",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  }
}
